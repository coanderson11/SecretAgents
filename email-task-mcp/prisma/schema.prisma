// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emails              Email[]
  tasks               Task[]
  drafts              Draft[]
  meetings            Meeting[]
  meetingPreps        MeetingPrep[]
  agentActivities     AgentActivity[]
  uploadedFiles       UploadedFile[]
  insights            Insight[]
  campaigns           RecommendedCampaign[]
  points              UserPoints?
}

model Email {
  id         String   @id @default(uuid())
  sessionId  String
  subject    String
  from       String
  body       String
  createdAt  DateTime @default(now())

  session  Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tasks    Task[]
  drafts   Draft[]
  meetings Meeting[]

  @@index([sessionId])
}

model Task {
  id          String       @id @default(uuid())
  sessionId   String
  emailId     String?
  title       String
  description String?
  dueDate     DateTime?
  priority    String @default("MEDIUM")
  category    String?
  status      String   @default("PENDING")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  email   Email?  @relation(fields: [emailId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([status])
}

// TaskPriority values: HIGH, MEDIUM, LOW
// TaskStatus values: PENDING, IN_PROGRESS, COMPLETED

model Draft {
  id            String      @id @default(uuid())
  sessionId     String
  emailId       String?
  taskId        String?
  subject       String
  body          String
  recipientTo   String
  status        String @default("PENDING")
  sentAt        DateTime?
  contextUsed   Boolean     @default(false)
  contextSources String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  email   Email?  @relation(fields: [emailId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([status])
}

model Meeting {
  id          String       @id @default(uuid())
  sessionId   String
  emailId     String?
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  attendees   String?
  category    String?
  createdAt   DateTime     @default(now())

  session     Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  email       Email?        @relation(fields: [emailId], references: [id], onDelete: SetNull)
  preparation MeetingPrep?

  @@index([sessionId])
}

model MeetingPrep {
  id              String   @id @default(uuid())
  meetingId       String   @unique
  sessionId       String
  prepDocument    String
  contextSources  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// DraftStatus values: PENDING, SENT, DISCARDED

model AgentActivity {
  id          String         @id @default(uuid())
  sessionId   String
  activityType String
  action      String
  details     String?
  status      String @default("PENDING_REVIEW")
  createdAt   DateTime       @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([status])
}

model UploadedFile {
  id           String   @id @default(uuid())
  sessionId    String
  fileName     String
  fileType     String
  fileSize     Int
  contentHash  String   @unique
  content      String
  metadata     String?
  stored       Boolean  @default(false)
  createdAt    DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Insight {
  id          String   @id @default(uuid())
  sessionId   String
  fileId      String
  keyFindings String
  summary     String
  recommendations String?
  metadata    String?
  createdAt   DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model RecommendedCampaign {
  id              String   @id @default(uuid())
  sessionId       String
  strategy        String
  emailTemplate   String
  subject         String
  recipientTips   String?
  followUpActions String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model UserPoints {
  id           String   @id @default(uuid())
  sessionId    String   @unique
  totalPoints  Int      @default(0)
  fileUploads  Int      @default(0)
  insightsGenerated Int @default(0)
  campaignsCreated Int @default(0)
  updatedAt    DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
