# Database
# IMPORTANT: Use absolute path for MCP mode
DATABASE_URL="file:c:/Users/YourUsername/email-task-app/backend/dev.db"

# Microsoft Azure AD OAuth
MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# Backend URL (for re-authentication)
BACKEND_URL=http://localhost:8025

# MCP Logging
LOG_FILE=./mcp.log

# Scheduler (set to false for on-demand mode)
ENABLE_SCHEDULER=false
